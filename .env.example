# Copy this file to ".env" and fill in your real values.

PORT=4000

# Your MongoDB Atlas connection string
MONGO_URI=your-mongodb-atlas-connection-string

# A long random string — keeps sign-ins secure. Change it.
JWT_SECRET=change-this-to-a-long-random-string

# Where your frontend runs (for browser security). "*" allows all during early dev.
CLIENT_ORIGIN=*

# Admin panel + admin API. A long random string; you enter this at /admin.html.
ADMIN_TOKEN=change-this-to-a-long-random-string

# Public base URL, used to build links in emails (e.g. password reset).
APP_URL=https://www.passreadyprep.com

# ── Email (Brevo) ───────────────────────────────────────────────────
# API key from Brevo → SMTP & API → API Keys. If unset, emails are logged
# to the server console instead of being sent (so nothing errors in dev).
BREVO_API_KEY=
MAIL_FROM_EMAIL=noreply@passreadyprep.com
MAIL_FROM_NAME=PassReady Prep

# ── Admin activity alerts ───────────────────────────────────────────
# Where activity/error alerts are emailed (defaults to MAIL_FROM_EMAIL).
ADMIN_ALERT_EMAIL=
# Optional SMS alerts via Brevo (needs SMS credits + registered sender).
# Phone in international format WITHOUT '+', e.g. 15551234567.
ADMIN_ALERT_SMS_TO=
SMS_SENDER=PassReady
# Comma list of event types to alert on (overrides the default set).
# Default alerts: user.registered, payment.succeeded, payment.failed,
# password.reset_completed — plus ALL errors, always.
ADMIN_ALERT_EVENTS=
# Set to 1 to silence all alerts (events are still logged to the panel).
ADMIN_ALERT_DISABLE=
# Minutes between alerts of the same kind, to avoid inbox floods (default 10).
ADMIN_ALERT_THROTTLE_MIN=10
# Optional: auto-delete activity events older than N days (unset = keep forever).
ACTIVITY_TTL_DAYS=
